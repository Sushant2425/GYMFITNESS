<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:fitsSystemWindows="true"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Professional Header with Back Arrow - Orange Gradient -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_orange_header"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="#FFFFFF"
            app:title="@string/membership_renewal"
            app:titleTextColor="#FFFFFF"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header Member Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMemberHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="8dp"
                app:strokeColor="#FF6B00"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="#1A1A1A">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Member Name -->
                    <TextView
                        android:id="@+id/tvMemberName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="John Doe"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <!-- Member Phone -->
                    <TextView
                        android:id="@+id/tvMemberPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/phone_prefix"
                        android:textColor="#BDBDBD"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp" />

                    <!-- Horizontal Divider -->
                    <View
                        android:id="@+id/dividerHeader1"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#332A2A2A"
                        android:layout_marginBottom="12dp" />

                    <!-- Plan Status -->
                    <TextView
                        android:id="@+id/tvPlanStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/plan_status_expired"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="#FF6B00"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Previous Plan Details Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPreviousPlan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="4dp"
                app:strokeColor="#FF6B00"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="#1A1A1A">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/previous_plan_details"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="20dp" />

                    <!-- Plan Type Row -->
                    <LinearLayout
                        android:id="@+id/rowPreviousPlanType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/plan_type_label"
                            android:textColor="#9E9E9E"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvPreviousPlanType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1 Month"
                            android:textColor="#FF9800"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:id="@+id/dividerPrevious1"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#332A2A2A"
                        android:layout_marginBottom="12dp" />

                    <!-- Start Date Row -->
                    <LinearLayout
                        android:id="@+id/rowPreviousStartDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/start_date_label"
                            android:textColor="#9E9E9E"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvPreviousStartDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10/01/2026"
                            android:textColor="#BDBDBD"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:id="@+id/dividerPrevious2"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#332A2A2A"
                        android:layout_marginBottom="12dp" />

                    <!-- End Date Row -->
                    <LinearLayout
                        android:id="@+id/rowPreviousEndDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/end_date_label"
                            android:textColor="#9E9E9E"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvPreviousEndDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10/02/2026"
                            android:textColor="#FF6B00"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:id="@+id/dividerPrevious3"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#332A2A2A"
                        android:layout_marginBottom="12dp" />

                    <!-- Previous Fee Row -->
                    <LinearLayout
                        android:id="@+id/rowPreviousFee"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/previous_fee"
                            android:textColor="#9E9E9E"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvPreviousFee"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹200"
                            android:textColor="#FFC107"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Outstanding Balance Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOutstandingBalance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#332A1A"
                app:strokeColor="#FFC107"
                app:strokeWidth="1dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/outstanding_balance"
                        android:textColor="#FFC107"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvOutstandingBalance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹164"
                        android:textColor="#FFC107"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- New Plan Selection Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNewPlan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:strokeColor="#FF6B00"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="#1A1A1A">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/renew_new_plan"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="20dp" />

                    <!-- Quick Renew Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnQuickRenew"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="@string/quick_renew_same_plan"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:iconTint="#FFFFFF"
                        app:cornerRadius="10dp"
                        app:backgroundTint="#FF6B00"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/or_select_new_plan"
                        android:textColor="#9E9E9E"
                        android:textSize="13sp"
                        android:layout_gravity="center"
                        android:layout_marginVertical="12dp" />

                    <!-- Plan Type Dropdown -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilNewPlanType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/select_new_plan"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_marginBottom="16dp"
                        app:boxStrokeColor="#FF6B00"
                        app:hintTextColor="#FF6B00"
                        app:boxBackgroundColor="#2C2C2C">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/spinnerNewPlanType"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Start Date Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilNewStartDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/new_start_date"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
                        app:startIconTint="#FF9800"
                        app:boxStrokeColor="#FF6B00"
                        app:hintTextColor="#FF6B00"
                        app:boxBackgroundColor="#2C2C2C"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNewStartDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:clickable="true"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- End Date Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilNewEndDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/end_date_auto_calculated"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:startIconDrawable="@android:drawable/ic_menu_today"
                        app:startIconTint="#FF9800"
                        app:boxStrokeColor="#FF6B00"
                        app:hintTextColor="#FF6B00"
                        app:boxBackgroundColor="#2C2C2C"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNewEndDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:textColor="#BDBDBD"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Plan Fee Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilNewPlanFee"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/plan_fee"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:prefixText="₹"
                        app:prefixTextColor="#FF6B00"
                        app:boxStrokeColor="#FF6B00"
                        app:hintTextColor="#FF6B00"
                        app:boxBackgroundColor="#2C2C2C"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNewPlanFee"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Payment Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPaymentSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:strokeColor="#FF6B00"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="#1A1A1A">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/payment_summary"
                        android:textColor="#FF9800"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- New Plan Fee Row -->
                    <LinearLayout
                        android:id="@+id/rowSummaryNewPlan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/new_plan_fee"
                            android:textColor="#9E9E9E"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvSummaryNewPlan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0"
                            android:textColor="#FFC107"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Previous Due Row -->
                    <LinearLayout
                        android:id="@+id/layoutPreviousDue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/plus_previous_due"
                            android:textColor="#FFC107"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvSummaryPreviousDue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0"
                            android:textColor="#FFC107"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <!-- Main Divider -->
                    <View
                        android:id="@+id/dividerSummary"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="#FF6B00"
                        android:layout_marginVertical="12dp" />

                    <!-- Total Payable -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/total_payable"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTotalPayable"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0"
                            android:textColor="#FF6B00"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Primary Action Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnProceedToPayment"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/proceed_to_payment"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:icon="@android:drawable/ic_menu_send"
                app:iconTint="#FFFFFF"
                app:iconGravity="start"
                app:cornerRadius="10dp"
                app:backgroundTint="#FF6B00"
                android:layout_marginBottom="16dp" />

            <!-- Progress Indicator -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="#FF6B00"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:strokeColor="#FF6B00"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="#1A1A1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvPaymentId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/id_prefix"
            android:textSize="11sp"
            android:textColor="#9E9E9E"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/paid_amount_display"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FF6B00"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvMode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/cash"
                android:textColor="#FF9800"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/paid_uppercase"
                android:textColor="#FFC107"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/date_prefix"
            android:textSize="13sp"
            android:textColor="#BDBDBD"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvRemaining"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/remaining_prefix_short"
            android:textSize="14sp"
            android:textColor="#FFC107"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
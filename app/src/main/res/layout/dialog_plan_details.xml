<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#1A1A1A">

    <!-- Plan Icon and Name -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/tvDialogPlanName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/plan_name_label"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/tvDialogStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#332A1A"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="@string/active"
            android:textSize="12sp"
            android:textColor="#FF6B00"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#332A2A2A"
        android:layout_marginBottom="20dp"/>

    <!-- Plan Details Grid -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="3"
        android:alignmentMode="alignMargins"
        android:columnOrderPreserved="false"
        android:padding="8dp">

        <!-- Duration -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#2C2C2C"
            android:layout_margin="4dp"
            android:gravity="center"
            android:minHeight="100dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_calendar_small"
                app:tint="#FF9800"
                android:layout_marginBottom="8dp"
                android:contentDescription="@string/duration"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/duration"
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvDialogDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/one_month"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FF9800"/>

        </LinearLayout>

        <!-- Fee -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#2C2C2C"
            android:layout_margin="4dp"
            android:gravity="center"
            android:minHeight="100dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_money"
                app:tint="#FF6B00"
                android:layout_marginBottom="8dp"
                android:contentDescription="@string/fee"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fee"
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvDialogFee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹ 1500"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FF6B00"/>

        </LinearLayout>

        <!-- Created Date -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_columnSpan="2"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#2C2C2C"
            android:layout_margin="4dp"
            android:gravity="center">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_input_add"
                app:tint="#FFC107"
                android:layout_marginBottom="8dp"
                android:contentDescription="@string/created_on"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/created_on"
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvDialogCreated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jan 25, 2024"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFC107"/>

        </LinearLayout>

    </GridLayout>

    <!-- Plan ID -->
    <TextView
        android:id="@+id/tvPlanId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/plan_id_prefix"
        android:textSize="10sp"
        android:textColor="#9E9E9E"
        android:fontFamily="monospace"
        android:visibility="gone"/>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardMember"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#FF6B00"
    app:cardBackgroundColor="#1A1A1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Main Content Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp"
            android:gravity="center_vertical">

            <!-- Avatar with Status Indicator -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone">

                <androidx.cardview.widget.CardView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="22dp"
                    android:visibility="gone"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#332A1A">

                    <TextView
                        android:id="@+id/tvInitial"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FF6B00"
                        android:text="M" />

                </androidx.cardview.widget.CardView>

                <!-- Status Indicator Dot -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/statusIndicator"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_gravity="bottom|end"
                    android:visibility="gone"
                    app:cardCornerRadius="6dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="#FF6B00" />

            </FrameLayout>

            <!-- Member Information -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_margin="4dp">

                <!-- Name and Status Badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvMemberName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/member_name"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/expired"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_status_expired" />

                </LinearLayout>

                <!-- Phone Number -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@android:drawable/stat_sys_phone_call"
                        app:tint="#9E9E9E"
                        android:contentDescription="@string/phone" />

                    <TextView
                        android:id="@+id/tvMemberPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:text="+91 1234567890"
                        android:textSize="12sp"
                        android:textColor="#BDBDBD" />

                </LinearLayout>

                <!-- Plan Details -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical">

                    <!-- Plan Type Badge -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp">

                        <TextView
                            android:id="@+id/tvPlanType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/one_month_short"
                            android:textSize="11sp"
                            android:textColor="#FF9800"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Divider 1 -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="16dp"
                        android:background="#332A2A2A" />

                    <!-- Pending Amount -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pending_colon"
                            android:textSize="10sp"
                            android:textColor="#9E9E9E" />

                        <TextView
                            android:id="@+id/tvOutstandingBalance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="₹500"
                            android:textSize="11sp"
                            android:textColor="#FFC107"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Divider 2 -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="16dp"
                        android:background="#332A2A2A" />

                    <!-- Expiry Info with Icon -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/ivExpiryIcon"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@android:drawable/ic_menu_recent_history"
                            app:tint="#FF6B00"
                            android:contentDescription="@string/expired" />

                        <TextView
                            android:id="@+id/tvEndDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:text="@string/days_ago"
                            android:textSize="11sp"
                            android:textColor="#FF6B00"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Outstanding Balance Row -->
                <LinearLayout
                    android:id="@+id/layoutDues"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:gravity="center_vertical"
                    android:background="#332A1A"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/outstanding_balance_colon"
                        android:textSize="11sp"
                        android:textColor="#FF9800" />

                    <TextView
                        android:id="@+id/tvOutstandingAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textSize="12sp"
                        android:textColor="#FFC107"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:id="@+id/dividerLine"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:background="#332A2A2A"
            android:visibility="gone" />

        <!-- Action Buttons -->
        <LinearLayout
            android:id="@+id/layoutExpiredActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:paddingEnd="10dp"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRenewPlan"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="@string/renew_plan"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                app:cornerRadius="8dp"
                app:backgroundTint="#FF6B00"
                app:elevation="1dp"
                style="@style/Widget.MaterialComponents.Button" />

        </LinearLayout>

        <!-- Bottom Indicator -->
        <View
            android:id="@+id/viewBottomIndicator"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#FF6B00"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
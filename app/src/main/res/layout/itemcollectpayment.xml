<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:strokeColor="#FF6B00"
    app:strokeWidth="1dp"
    android:layout_margin="8dp"
    app:cardBackgroundColor="#1A1A1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="0dp">

        <!-- Table Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#332A1A"
            android:paddingVertical="10dp"
            android:paddingHorizontal="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="@string/amount_uppercase"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#FF9800" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:text="@string/mode_uppercase"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#FF9800"
                android:gravity="center" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="@string/date_uppercase"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#FF9800"
                android:gravity="center" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:text="@string/status_uppercase"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#FF9800"
                android:gravity="center" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1.5dp"
            android:background="#FF6B00" />

        <!-- Data Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="14dp"
            android:paddingHorizontal="12dp">

            <TextView
                android:id="@+id/tvAmount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="₹500"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FF6B00" />

            <TextView
                android:id="@+id/tvMode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:text="@string/cash"
                android:textSize="13sp"
                android:textColor="#FF9800"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="01/01/2026"
                android:textSize="12sp"
                android:textColor="#BDBDBD"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:text="@string/paid_uppercase"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#FFC107"
                android:background="#332A1A"
                android:paddingHorizontal="6dp"
                android:paddingVertical="3dp"
                android:gravity="center" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#332A2A2A" />

        <!-- Remaining Balance -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="8dp"
            android:paddingHorizontal="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/remaining_colon"
                android:textSize="12sp"
                android:textColor="#9E9E9E" />

            <TextView
                android:id="@+id/tvRemaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹500"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFC107" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#332A2A2A" />

        <!-- Transaction ID -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="8dp"
            android:paddingHorizontal="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/id_colon"
                android:textSize="10sp"
                android:textColor="#9E9E9E" />

            <TextView
                android:id="@+id/tvPaymentId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="abc-123-xyz"
                android:textSize="10sp"
                android:textColor="#9E9E9E"
                android:fontFamily="monospace" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="#1A1A1A"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:strokeColor="#FF6B00"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="0dp">

        <!-- ===== TABLE HEADER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#332A1A"
                android:paddingVertical="14dp"
                android:paddingHorizontal="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2.5"
                    android:text="@string/plan_name_uppercase"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"
                    android:maxLines="1"
                    android:letterSpacing="0.05" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.5"
                    android:text="@string/fee_rupee"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"
                    android:gravity="center"
                    android:letterSpacing="0.05" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.5"
                    android:text="@string/duration_uppercase"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"
                    android:gravity="center"
                    android:letterSpacing="0.05" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.5"
                    android:text="@string/status_uppercase"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"
                    android:gravity="center"
                    android:letterSpacing="0.05" />

            </LinearLayout>

            <!-- Header Bottom Border -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#FF6B00" />

        </LinearLayout>

        <!-- ===== DATA ROW ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Row Divider Top -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#332A2A2A" />

            <!-- Data Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="16dp"
                android:paddingHorizontal="12dp"
                android:background="#1A1A1A">

                <!-- Left Vertical Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#332A2A2A"
                    android:layout_marginVertical="-16dp" />

                <TextView
                    android:id="@+id/tvPlanName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2.5"
                    android:text="@string/premium_plan"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:paddingStart="8dp" />

                <!-- Vertical Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#332A2A2A"
                    android:layout_marginVertical="-16dp" />

                <TextView
                    android:id="@+id/tvPlanFee"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.5"
                    android:text="₹2,500"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FF6B00"
                    android:gravity="center" />

                <!-- Vertical Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#332A2A2A"
                    android:layout_marginVertical="-16dp" />

                <TextView
                    android:id="@+id/tvMonths"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.5"
                    android:text="@string/three_months"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"
                    android:gravity="center" />

                <!-- RESTORED: tvPlanDuration - Kept as is -->
                <TextView
                    android:id="@+id/tvPlanDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="3dp"
                    android:visibility="gone"
                    android:text="@string/one_month_short"
                    android:textSize="11sp"
                    android:textColor="#FFC107"
                    android:textStyle="bold" />

                <!-- Vertical Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#332A2A2A"
                    android:layout_marginVertical="-16dp" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.5"
                    android:text="@string/active_uppercase"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FF6B00"
                    android:background="#332A1A"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:gravity="center"
                    android:layout_gravity="center" />

                <!-- Right Vertical Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#332A2A2A"
                    android:layout_marginVertical="-16dp" />

            </LinearLayout>

            <!-- Row Divider Bottom -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#332A2A2A" />

        </LinearLayout>

        <!-- ===== ACTION BUTTONS ROW ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:paddingVertical="10dp"
            android:paddingHorizontal="12dp"
            android:background="#1A1A1A">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEdit"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/edit_uppercase"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FF9800"
                android:layout_marginEnd="8dp"
                app:icon="@drawable/ic_edit"
                app:iconSize="16dp"
                app:iconPadding="6dp"
                app:iconTint="#FF9800"
                app:cornerRadius="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/delete_uppercase"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#F44336"
                app:icon="@drawable/ic_delete"
                app:iconSize="16dp"
                app:iconPadding="6dp"
                app:iconTint="#F44336"
                app:cornerRadius="6dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
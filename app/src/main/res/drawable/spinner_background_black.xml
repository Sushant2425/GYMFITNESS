<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <layer-list>
            <item>
                <shape>
                    <solid android:color="#1A1A1A" />
                    <corners android:radius="8dp" />
                    <stroke android:width="1dp" android:color="#FF6B00" />
                </shape>
            </item>
            <item android:gravity="end" android:right="12dp">
                <layer-list>
                    <item>
                        <shape>
                            <solid android:color="#00000000" />
                        </shape>
                    </item>
                    <item>
                        <bitmap android:src="@android:drawable/arrow_down_float" android:gravity="center" />
                    </item>
                </layer-list>
            </item>
        </layer-list>
    </item>
</selector>
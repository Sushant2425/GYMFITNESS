<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="DialogTheme" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="colorPrimary">#1A237E</item>
        <item name="colorAccent">#D32F2F</item>
    </style>
    <!-- Circular FAB Style -->
    <style name="CircularFAB" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
    <!-- Spinner Theme for Dark Background -->
    <style name="SpinnerTheme" parent="Widget.AppCompat.Spinner">
        <item name="android:popupBackground">#2C2C2C</item>
        <item name="android:background">@drawable/spinner_background_black</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:dropDownSelector">?attr/colorControlHighlight</item>
    </style>

    <!-- Custom Dropdown Theme -->
    <style name="CustomDropDownTheme" parent="ThemeOverlay.AppCompat.Dark">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:background">#1A1A1A</item>
        <item name="android:dropDownListViewStyle">@style/MyDropDownListViewStyle</item>
    </style>

    <style name="MyDropDownListViewStyle" parent="Widget.AppCompat.ListView.DropDown">
        <item name="android:divider">#FF6B00</item>
        <item name="android:dividerHeight">1dp</item>
        <item name="android:background">#2C2C2C</item>
        <item name="android:listSelector">?attr/colorControlHighlight</item>
    </style>
    <!-- Optional: Custom FAB Style with Shadow -->
    <style name="CustomFABStyle" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="elevation">12dp</item>
        <item name="pressedTranslationZ">16dp</item>
        <item name="hoveredFocusedTranslationZ">14dp</item>
        <item name="borderWidth">0dp</item>
        <item name="fabSize">normal</item>
    </style>
</resources>